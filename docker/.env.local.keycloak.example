# =============================================================================
# FstvlPress - Local Keycloak Testing Environment
# =============================================================================
# Copy this file to .env in the docker/ directory for local Keycloak testing.
#
# This configuration uses a local Keycloak instance instead of an external
# Keycloak server, allowing you to test authentication flows locally.
#
# Usage:
#   1. Copy this file to docker/.env
#   2. Run: cd docker && docker compose -f docker-compose.keycloak-only.yml up -d
#   3. Wait for Keycloak to start (~60s): docker logs -f fstvlpress-keycloak-local
#   4. Start frontend: VITE_USE_LOCAL_KEYCLOAK=true npm run dev
#   5. Start backend: see backend/.env.local.keycloak.example
#
# Keycloak Admin Console: http://localhost:8180
#   Username: admin
#   Password: admin
#
# Pre-configured Test Users:
#   - admin@example.local / admin123 (admin + editor roles)
#   - editor@example.local / editor123 (editor role)
#   - viewer@example.local / viewer123 (viewer role)
# =============================================================================

# No additional env vars needed for docker-compose.keycloak-only.yml
# All defaults are configured in the compose file
