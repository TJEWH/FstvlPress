# =============================================================================
# FstvlPress - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment
# For Portainer: Set these as environment variables in the stack configuration
#
# SECURITY: For production, use strong unique passwords. Generate with:
#   openssl rand -base64 32
# Never use default credentials (minioadmin, admin, changeme) in production.
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
# Image registry prefix for Portainer stack deployments (trailing slash required)
REGISTRY=ghcr.io/your-org/
# Use TAG=dev for the development stack and TAG=prod for the production stack.
# Do not use latest for hosted stacks; branch workflows publish separate tags.
TAG=prod
FRONTEND_PORT=80
APP_DISPLAY_NAME=FstvlPress
API_PROXY_READ_TIMEOUT=900s
API_PROXY_SEND_TIMEOUT=900s
API_PROXY_CONNECT_TIMEOUT=75s
BACKUP_UPLOAD_MAX_BODY_SIZE=1g
BACKUP_PROXY_READ_TIMEOUT=3600s
BACKUP_PROXY_SEND_TIMEOUT=3600s
BACKUP_CLIENT_BODY_TIMEOUT=3600s

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGO_DB=2026
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_mongodb_password

# -----------------------------------------------------------------------------
# MinIO S3 Configuration (required for production)
# -----------------------------------------------------------------------------
# Generate strong credentials: openssl rand -base64 32
MINIO_ROOT_USER=your_minio_admin_user
MINIO_ROOT_PASSWORD=your_strong_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=fstvlpress-assets

# Optional: Service account for backend (least-privilege bucket access only).
# If set, minio-setup creates a restricted access key. Otherwise backend uses root.
# S3_ACCESS_KEY_ID=fstvlpress-app
# S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
# Public URL for accessing assets (through reverse proxy or direct)
S3_PUBLIC_BASE_URL=https://your-domain.com/storage

# -----------------------------------------------------------------------------
# OIDC/Keycloak Configuration
# -----------------------------------------------------------------------------
# Frontend OIDC settings
# IMPORTANT: This client must be a public SPA client (PKCE), never confidential.
OIDC_URL=https://your-keycloak-server.com/auth
OIDC_REALM_NAME=your-realm
OIDC_CLIENT_ID=fstvlpress-web
# Optional server-side fallback for confidential clients during migration.
# Never exposed to the browser; used only by nginx token proxy if set.
OIDC_CLIENT_SECRET=

# Backend/API client (for token validation) - confidential client
KEYCLOAK_SERVER_URL=https://your-keycloak-server.com/auth
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=fstvlpress-api
KEYCLOAK_CLIENT_SECRET=your_api_client_secret_here

# Optional: restrict admin access to specific Keycloak roles (comma-separated).
# If empty or unset, any authenticated user gets admin rights.
# KEYCLOAK_ADMIN_ROLES=admin

# Included Keycloak instance
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin_password
KC_DB_USER=keycloak
KC_DB_PASSWORD=changeme_keycloak_db_password
KC_HOSTNAME=auth.your-domain.com
KEYCLOAK_PORT=8080

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com,localhost:8080
