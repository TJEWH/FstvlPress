# =============================================================================
# FstvlPress Backend - Local Keycloak Testing Environment
# =============================================================================
# Copy this file to .env in the backend/ directory for local Keycloak testing.
#
# This configuration connects to a local Keycloak instance started with:
#   cd docker && docker compose -f docker-compose.keycloak-only.yml up -d
#
# Usage:
#   1. Copy this file to backend/.env
#   2. Start the backend: python -m uvicorn app.main:app --reload --port 8080
#
# The backend will validate tokens against the issuer carried by local Keycloak tokens.
# =============================================================================
APP_NAME=FstvlPress
SITE_SLUG=fstvlpress

# Environment mode: local-keycloak enables real token validation against local Keycloak
# (as opposed to "dev" which bypasses all auth)
ENVIRONMENT=local-keycloak

# MongoDB (same as regular local dev - port 27017)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=2026

# Optional: restrict admin access to specific roles (comma-separated).
# If empty or unset, any authenticated user gets admin rights.
KEYCLOAK_ADMIN_ROLES=admin

# Backend-issued app-token signing secret.
APP_TOKEN_SECRET=local-dev-app-token-secret

# MinIO S3 Storage (local Docker)
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=local-minio
S3_SECRET_ACCESS_KEY=local-minio-password
S3_BUCKET=fstvlpress-assets
S3_PUBLIC_BASE_URL=http://localhost:9000/fstvlpress-assets

# CORS - allow local development origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
