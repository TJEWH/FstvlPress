# Backend environment template

APP_NAME=FstvlPress
SITE_SLUG=fstvlpress
ENVIRONMENT=dev

MONGO_URI=mongodb://localhost:27017
MONGO_DB=2026

# Optional: restrict admin access to specific Keycloak roles (comma-separated).
# If empty or unset, any authenticated user gets admin rights.
KEYCLOAK_ADMIN_ROLES=

STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=fstvlpress-assets
S3_PUBLIC_BASE_URL=http://localhost:9000/fstvlpress-assets

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Generate fresh values before enabling these features.
BACKUP_API_TOKEN=
APP_TOKEN_SECRET=
